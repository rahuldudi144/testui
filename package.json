{
  "name": "db-agent-testui",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run dev:server & bun run dev:client",
    "predev": "bun scripts/free-dev-port.ts 4000",
    "dev:server": "bun --watch --env-file=.env server/index.ts",
    "dev:client": "vite --config client/vite.config.ts",
    "build": "vite build --config client/vite.config.ts",
    "start": "bun --env-file=.env server/index.ts",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "prisma:generate": "bun --env-file=.env prisma generate",
    "prisma:migrate": "bun --env-file=.env prisma migrate dev",
    "prisma:seed": "bun --env-file=.env prisma/seed.ts",
    "db:seed": "bun run prisma:seed",
    "db:setup": "bun run docker:up && bun run prisma:migrate && bun run db:seed",
    "postinstall": "bun --env-file=.env prisma generate"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.3",
    "@langchain/anthropic": "^0.3.24",
    "@langchain/core": "^0.3.58",
    "@langchain/google": "^0.2.1",
    "@langchain/langgraph": "^0.2.72",
    "@langchain/ollama": "^0.2.4",
    "@langchain/openai": "^0.5.10",
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-tabs": "^1.1.15",
    "bcryptjs": "^3.0.2",
    "clsx": "^2.1.1",
    "dotenv": "^16.5.0",
    "hono": "^4.7.11",
    "lucide-react": "^1.21.0",
    "mysql2": "^3.14.1",
    "pg": "^8.16.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.18.1",
    "recharts": "^3.9.2",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^3.25.51"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/bun": "^1.2.15",
    "@types/pg": "^8.15.2",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.5.2",
    "prisma": "^7.0.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
