generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String               @id @default(cuid())
  username         String               @unique
  passwordHash     String
  createdAt        DateTime             @default(now())
  activeDatabaseId String?
  activeDatabase   DatabaseConnection?  @relation("ActiveDatabase", fields: [activeDatabaseId], references: [id], onDelete: SetNull)
  activeAgentId    String?
  activeAgent      AgentProfile?        @relation("ActiveAgent", fields: [activeAgentId], references: [id], onDelete: SetNull)
  conversations    Conversation[]
  databases        DatabaseConnection[] @relation("UserDatabases")
  agents           AgentProfile[]       @relation("UserAgents")
  workflowTests    WorkflowTest[]
  workflowTestRuns WorkflowTestRun[]
  queryExecutions  QueryExecution[]
}

model AgentProfile {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation("UserAgents", fields: [userId], references: [id], onDelete: Cascade)
  activeForUsers User[]   @relation("ActiveAgent")
  name           String
  systemPrompt   String?  @db.Text
  llmProvider    String?
  modelName      String?
  apiKey         String?  @db.Text
  baseUrl        String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
}

model DatabaseConnection {
  id               String    @id @default(cuid())
  userId           String
  user             User      @relation("UserDatabases", fields: [userId], references: [id], onDelete: Cascade)
  activeForUsers   User[]    @relation("ActiveDatabase")
  name             String
  dbType           String
  dbUri            String    @db.Text
  businessContext  String?   @db.Text
  dbMetadata       Json?
  schemaSyncedAt   DateTime?
  schemaSyncStatus String    @default("idle")
  schemaSyncError  String?   @db.Text
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([userId])
}

model Conversation {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  messages  Message[]

  @@index([userId])
}

model Message {
  id             String           @id @default(cuid())
  conversationId String
  conversation   Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String
  content        String           @db.Text
  generatedSql   String?          @db.Text
  debugData      Json?
  createdAt      DateTime         @default(now())
  queryExecution QueryExecution?

  @@index([conversationId])
}

model WorkflowTest {
  id        String              @id @default(cuid())
  userId    String
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  dryRun    Boolean             @default(false)
  delayMs   Int                 @default(0)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  groups    WorkflowTestGroup[]
  runs      WorkflowTestRun[]

  @@unique([userId, name])
  @@index([userId, updatedAt(sort: Desc)])
}

enum WorkflowTestGroupKind {
  manual
  failures
}

model WorkflowTestGroup {
  id             String                @id @default(cuid())
  workflowTestId String
  workflowTest   WorkflowTest          @relation(fields: [workflowTestId], references: [id], onDelete: Cascade)
  name           String
  kind           WorkflowTestGroupKind @default(manual)
  sortOrder      Int                   @default(0)
  queries        WorkflowTestQuery[]
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@index([workflowTestId, sortOrder])
}

model WorkflowTestQuery {
  id              String            @id @default(cuid())
  groupId         String
  group           WorkflowTestGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  query           String            @db.Text
  sortOrder       Int               @default(0)
  sourceRunId     String?
  sourceRun       WorkflowTestRun?  @relation(fields: [sourceRunId], references: [id], onDelete: SetNull)
  sourceGroupName String?
  createdAt       DateTime          @default(now())

  @@index([groupId, sortOrder])
}

model WorkflowTestRun {
  id              String              @id @default(cuid())
  userId          String
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  workflowTestId  String
  workflowTest    WorkflowTest        @relation(fields: [workflowTestId], references: [id], onDelete: Cascade)
  testName        String
  dryRun          Boolean
  delayMs         Int
  database        Json
  summary         Json
  results         Json
  ranAt           DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  sourcedQueries  WorkflowTestQuery[]
  queryExecutions QueryExecution[]

  @@index([userId, ranAt(sort: Desc)])
  @@index([workflowTestId, ranAt(sort: Desc)])
}

enum QueryExecutionSource {
  workflow_test
  chat
}

model QueryExecution {
  id                String               @id @default(cuid())
  userId            String
  user              User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  source            QueryExecutionSource
  workflowTestRunId String?
  workflowTestRun   WorkflowTestRun?     @relation(fields: [workflowTestRunId], references: [id], onDelete: Cascade)
  messageId         String?              @unique
  message           Message?             @relation(fields: [messageId], references: [id], onDelete: Cascade)
  queryKey          String?
  attemptNumber     Int                  @default(1)
  query             String               @db.Text
  groupName         String?
  status            String?
  promptTokens      Int                  @default(0)
  completionTokens  Int                  @default(0)
  totalTokens       Int                  @default(0)
  llmCallCount      Int                  @default(0)
  llmCalls          Json?
  durationMs        Int                  @default(0)
  requestId         String?
  ranAt             DateTime             @default(now())

  @@index([userId, ranAt(sort: Desc)])
  @@index([workflowTestRunId])
  @@index([messageId])
}
